# MCP OpenAPI Service 环境变量配置示例
# 复制此文件为 .env 或 .env.local 并填入实际值

# ===== MCP 服务配置 =====
# 服务监听地址（可选，覆盖 config.yaml 中的 mcp.host）
# MCP_HOST=0.0.0.0

# 服务端口（可选，覆盖 config.yaml 中的 mcp.port）
# MCP_PORT=8080

# 服务名称（可选，覆盖 config.yaml 中的 mcp.name）
# MCP_NAME=ticket-mcp

# 传输方式：sse 或 stdio（可选，覆盖 config.yaml 中的 mcp.transport）
# MCP_TRANSPORT=sse

# ===== OpenAPI 后端配置 =====
# 后端 API 基础地址（必填）
API_BASE_URL=http://localhost:8888

# API 认证 Token（必填，根据实际认证方式调整 header 名称）
API_AUTH_TOKEN=your-api-token-here

# 如果需要自定义认证 header 名称（可选，默认为 X-Api-Token）
# API_AUTH_HEADER_NAME=X-Api-Token

# ===== 日志配置（可选）=====
# LOG_LEVEL=INFO
# LOG_DIR=./logs
# LOG_FILE=app.log
# LOG_RETENTION_DAYS=3

# ===== 配置文件路径（可选）=====
# CONFIG_PATH=config.yaml
